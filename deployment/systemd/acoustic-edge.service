[Unit]
Description=Acoustic Audit Edge Publisher
After=network.target

[Service]
Type=simple
User=pi
WorkingDirectory=/home/pi/Acoustic-Audit-System/edge
EnvironmentFile=/home/pi/Acoustic-Audit-System/edge/.env
ExecStart=/usr/bin/python acoustic_edge.py
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target